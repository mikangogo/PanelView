root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[/src/**]
indent_size = 4

[/testing/**]
indent_size = 4

[*.bat]
charset = unset
end_of_line = crlf

[*.{cpp,hpp,c,h}]
charset = utf-8-bom
indent_size = 4
